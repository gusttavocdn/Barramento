{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "creditbus-facade",
    "Topic": "creditbus.ingestion",
    "DlqTopic": "creditbus.ingestion.dlq",
    "ChannelCapacity": 1000,
    "Retry": {
      "MaxAttempts": 3,
      "InitialDelayMs": 1000,
      "MaxDelayMs": 30000,
      "JitterFactor": 0.2
    }
  }
}
